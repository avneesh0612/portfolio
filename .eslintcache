ojects.map(function (projects) {\n      var projectImage = \"images/portfolio/\" + projects.image;\n      return (\n        <div key={projects.title} className=\"columns portfolio-item\">\n          <div\n            className=\"item-wrap\"\n            data-aos=\"zoom-in\"\n            data-aos-delay=\"200\"\n            data-aos-duration=\"900\"\n          >\n            <a href={projects.url} target=\"_blank\" title={projects.title}>\n              <img alt={projects.title} src={projectImage} />\n              <div className=\"overlay\">\n                <div className=\"portfolio-item-meta\">\n                  <h5>{projects.title}</h5>\n                  <p>{projects.category}</p>\n                </div>\n              </div>\n              <div className=\"link-icon\">\n                <i className=\"fa fa-link\"></i>\n              </div>\n            </a>\n          </div>\n        </div>\n      );\n    });\n  }\n\n  return (\n    <section id=\"portfolio\">\n      <div className=\"row\">\n        <div className=\"twelve columns collapsed\">\n          <h1>Check Out Some of My Works.</h1>\n\n          <div\n            id=\"portfolio-wrapper\"\n            className=\"bgrid-quarters s-bgrid-thirds cf\"\n          >\n            {projects}\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n};\n\nexport default Portfolio;\n","C:\\Users\\mamta\\Desktop\\Projects done\\Portfolio\\src\\Components\\Testimonials.js",[],"C:\\Users\\mamta\\Desktop\\Projects done\\Portfolio\\src\\Components\\Header.js",[],"C:\\Users\\mamta\\Desktop\\Projects done\\Portfolio\\src\\Components\\Skills.js",[],"C:\\Users\\mamta\\Desktop\\Projects done\\Portfolio\\src\\Components\\About.js",[],"C:\\Users\\mamta\\Desktop\\Projects done\\Portfolio\\src\\Components\\Contact.js",[],"C:\\Users\\mamta\\Desktop\\Projects done\\Portfolio\\src\\Components\\Resume.js",[],"C:\\Users\\mamta\\Desktop\\Projects done\\Portfolio\\src\\Components\\Droppable.js",[],"C:\\Users\\mamta\\Deskt